# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Active scenario for the MCP server (see scenarios/ directory), e.g. s01_clean_shortage
SCENARIO_ID=s01_clean_shortage

# Optional overrides for orchestrator/config.py's defaults — leave unset to use the confirmed
# defaults (Haiku 4.5 / Sonnet 4.5 via OpenRouter, temperature 0, 10 tool-loop iterations, 3
# CaseFile-correction attempts).
# INVESTIGATOR_MODEL=anthropic/claude-haiku-4.5
# REVIEWER_MODEL=anthropic/claude-sonnet-4.5
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# AGENT_TEMPERATURE=0.0
# MAX_TOOL_ITERATIONS=10
# MAX_INVESTIGATOR_ATTEMPTS=3
